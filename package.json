{
  "private": true,
  "type": "module",
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "all": "pnpm clean && pnpm build && pnpm test && pnpm lint && pnpm run docs && pnpm run docs-legacy",
    "clean": "rimraf docs/ && lerna run clean",
    "dev": "cross-env NODE_ENV=development SERVE=1 node ./bin/build.mjs",
    "build": "lerna run build",
    "test": "vitest run",
    "lint": "lerna run lint",
    "lint-fix": "lerna run lint-fix",
    "docs": "typedoc",
    "docs-legacy": "lerna run docs-legacy",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@gltf-transform/core": "^4.2.1",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.16",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-config-mdcs": "^5.0.0",
    "eslint-plugin-html": "^8.1.3",
    "globals": "^17.0.0",
    "husky": "^9.1.5",
    "lerna": "^9.0.3",
    "lint-staged": "^16.2.7",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.15",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.16"
  },
  "name": "three-vrm"
}
